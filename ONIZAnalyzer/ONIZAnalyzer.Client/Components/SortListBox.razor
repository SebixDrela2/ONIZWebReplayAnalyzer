@using System.Text.RegularExpressions
@using ONIZAnalyzer.Common.Models.Record

<div class="analyze-sort-wrapper">
    <button type="button"
            class="analyze-sort-header"
            @onclick="ToggleExpanded"
            @onclick:stopPropagation="true">

        <span class="analyze-sort-arrow @(_isExpanded ? "expanded" : "")">
            ▶
        </span>

        @if (SelectedOption is not null)
        {
            <span class="analyze-sort-prefix">
                @GetPrefix(SelectedOption.OptionType)
            </span>

            <span class="analyze-sort-name">
                @(SelectedOption.OptionType == OnizRecordOptionType.None
                    ? "None"
                    : FormatDisplayName(SelectedOption.OptionName))
            </span>
        }
    </button>

    @if (_isExpanded)
    {
        <div class="analyze-sort-dropdown">
            @foreach (var option in Options)
            {
                var isSelected = EqualityComparer<OnizRecordSortOption>
                    .Default.Equals(option, SelectedOption);

                <button type="button"
                        class="analyze-sort-item @(isSelected ? "selected" : "")"
                        @onclick="() => SelectOption(option)"
                        @onclick:stopPropagation="true">

                    <span class="analyze-sort-prefix">
                        @GetPrefix(option.OptionType)
                    </span>

                    <span class="analyze-sort-name">
                        @(option.OptionType == OnizRecordOptionType.None
                            ? "None"
                            : FormatDisplayName(option.OptionName))
                    </span>
                </button>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public OnizRecordSortOption[] Options { get; set; } = [];

    [Parameter]
    public EventCallback<OnizRecordSortOption> SelectedOptionChanged { get; set; }

    [Parameter]
    public OnizRecordSortOption? SelectedOption { get; set; }

    private bool _isExpanded;

    protected override void OnParametersSet()
    {
        if (SelectedOption is null && Options.Length > 0)
        {
            SelectedOption = Options[0];
        }
    }

    private void ToggleExpanded()
    {
        _isExpanded = !_isExpanded;
    }

    private async Task SelectOption(OnizRecordSortOption option)
    {
        SelectedOption = option;
        _isExpanded = false;
        await SelectedOptionChanged.InvokeAsync(option);
    }

    private static string FormatDisplayName(string propertyName)
    {
        var result = Regex.Replace(propertyName, "(?<=[a-z])([A-Z])", " $1");
        result = Regex.Replace(result, "([A-Z]+)([A-Z][a-z])", "$1 $2");

        return result;
    }

    private static string GetPrefix(OnizRecordOptionType type) => type switch
    {
        OnizRecordOptionType.General => "G",
        OnizRecordOptionType.Marine => "M",
        OnizRecordOptionType.Zombie => "Z",
        _ => "-"
    };
}